rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // دا لسوكاني ستور 
     function isStoreAdmin() {
      return request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.role == "admin");
    }

    // عملاء المتجر (Phone Auth) — يبقى الوصول كما ضبطته سابقاً
    match /storefront_customers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // محتوى CMS: القراءة للعموم غير مطلوبة — التطبيق يقرأ عبر Admin SDK فقط.
    match /storefront_cms/{docId} {
      allow read, write: if false;
    }

    // نماذج المنتجات ثلاثية الأبعاد: القراءة عامة حتى تظهر أزرار 360°،
    // والكتابة المباشرة من العميل مقصورة على حسابات Firebase ذات custom claims إدارية.
    // مسارات API في Next.js تستخدم Admin SDK وتتجاوز هذه القواعد.
    match /product_3d_assets/{sku} {
      allow read: if true;
      allow create, update, delete: if isStoreAdmin();
    }

    //دا للملفات 
    function isSignedIn() {
      return request.auth != null;
    }

    function isFilesAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /fileCards/{cardId} {
      // Cards under a deactivated folder are hidden from the public.
      // Cards without a folder default to folderIsActive == true.
      allow read: if (
        resource.data.isActive == true &&
        resource.data.get('folderIsActive', true) == true
      ) || isFilesAdmin();
      allow create, update, delete: if isFilesAdmin();
    }

    match /fileFolders/{folderId} {
      allow read: if resource.data.isActive == true || isFilesAdmin();
      allow create, update, delete: if isFilesAdmin();
    }

    match /file_settings/{docId} {
      allow read: if true;
      allow write: if isFilesAdmin();
    }

    match /adminUsers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isFilesAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow create, update: if true;
      allow read, delete: if isFilesAdmin();
    }

    match /file_notifications/{id} {
      allow read, write: if isFilesAdmin();
    }

    // Fragment: ERP multi-tenant rules only (Sokany store / files collections excluded). Paste inside `match /databases/{database}/documents { ... }`.
    // Helpers use the `pl_` prefix for safe merge into a central rules file.
    // No rules_version / service wrapper / match databases wrapper / deny-all catch-all in this file.

    function pl_authSignedIn() {
      return request.auth != null;
    }

    function pl_currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function pl_currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function pl_currentRolePath() {
      return /databases/$(database)/documents/roles/$(pl_currentUserDoc().data.roleId);
    }

    function pl_currentRoleDoc() {
      return get(pl_currentRolePath());
    }

    function pl_isSuperAdmin() {
      return pl_authSignedIn()
        && exists(pl_currentUserPath())
        && pl_currentUserDoc().data.isSuperAdmin == true;
    }

    function pl_roleBelongsToTenant() {
      let rid = pl_currentUserDoc().data.roleId;
      return rid != null && rid != ''
        && exists(/databases/$(database)/documents/roles/$(rid))
        && get(/databases/$(database)/documents/roles/$(rid)).data.tenantId
          == pl_currentUserDoc().data.tenantId;
    }

    function pl_hasErpPermission(permissionKey) {
      return pl_authSignedIn()
        && exists(pl_currentUserPath())
        && exists(pl_currentRolePath())
        && pl_roleBelongsToTenant()
        && permissionKey in pl_currentRoleDoc().data.permissions
        && pl_currentRoleDoc().data.permissions[permissionKey] == true;
    }

    function pl_isActiveUser() {
      return pl_authSignedIn()
        && exists(pl_currentUserPath())
        && pl_currentUserDoc().data.isActive == true;
    }

    function pl_sameTenantWrite() {
      return pl_isActiveUser()
        && request.resource.data.keys().hasAll(['tenantId'])
        && request.resource.data.tenantId == pl_currentUserDoc().data.tenantId;
    }

    function pl_sameTenantUpdate() {
      return pl_isActiveUser()
        && resource.data.tenantId == pl_currentUserDoc().data.tenantId
        && request.resource.data.keys().hasAll(['tenantId'])
        && request.resource.data.tenantId == pl_currentUserDoc().data.tenantId;
    }

    /** During migration, docs may lack tenantId; treat as single-tenant legacy (backfill tenantId for strict multi-tenant isolation). */
    function pl_sameTenantOrLegacyRead() {
      return pl_isActiveUser()
        && (
          resource == null
          || !('tenantId' in resource.data)
          || resource.data.tenantId == pl_currentUserDoc().data.tenantId
        );
    }

    function pl_sameTenantOrLegacyWrite() {
      return pl_isActiveUser()
        && request.resource.data.keys().hasAll(['tenantId'])
        && request.resource.data.tenantId == pl_currentUserDoc().data.tenantId;
    }

    function pl_sameTenantOrLegacyUpdate() {
      return pl_isActiveUser()
        && (!('tenantId' in resource.data)
          || resource.data.tenantId == pl_currentUserDoc().data.tenantId)
        && request.resource.data.keys().hasAll(['tenantId'])
        && request.resource.data.tenantId == pl_currentUserDoc().data.tenantId;
    }

    function pl_isRepairBranchAdmin() {
      return pl_hasErpPermission('repair.branches.manage');
    }

    function pl_currentUserRepairBranchId() {
      return pl_currentUserDoc().data.repairBranchId;
    }

    function pl_currentUserRepairBranchIds() {
      return pl_currentUserDoc().data.repairBranchIds;
    }

    function pl_currentUserHasRepairBranch(branchId) {
      return (
        (pl_currentUserRepairBranchId() != null
          && pl_currentUserRepairBranchId() != ''
          && branchId == pl_currentUserRepairBranchId())
        || (pl_currentUserRepairBranchIds() is list
          && branchId in pl_currentUserRepairBranchIds())
      );
    }

    function pl_isTechnicianAssignedToBranch(branchId) {
      return branchId != null
        && branchId != ''
        && exists(/databases/$(database)/documents/repair_branches/$(branchId))
        && (
          get(/databases/$(database)/documents/repair_branches/$(branchId)).data.technicianIds is list
          && request.auth.uid in get(/databases/$(database)/documents/repair_branches/$(branchId)).data.technicianIds
        );
    }

    function pl_isBranchManager(branchId) {
      return branchId != null
        && branchId != ''
        && exists(/databases/$(database)/documents/repair_branches/$(branchId))
        && (
          get(/databases/$(database)/documents/repair_branches/$(branchId)).data.managerEmployeeId is string
          && get(/databases/$(database)/documents/repair_branches/$(branchId)).data.managerEmployeeId != ''
          && exists(
            /databases/$(database)/documents/employees/
            $(get(/databases/$(database)/documents/repair_branches/$(branchId)).data.managerEmployeeId)
          )
          && get(
            /databases/$(database)/documents/employees/
            $(get(/databases/$(database)/documents/repair_branches/$(branchId)).data.managerEmployeeId)
          ).data.userId == request.auth.uid
        );
    }

    function pl_canAccessRepairBranch(branchId) {
      return pl_currentUserHasRepairBranch(branchId)
        || pl_isTechnicianAssignedToBranch(branchId)
        || pl_isBranchManager(branchId);
    }

    function pl_canReadRepairBranchScoped() {
      return pl_sameTenantOrLegacyRead()
        && (
          pl_isRepairBranchAdmin()
          || (
            'branchId' in resource.data
            && pl_canAccessRepairBranch(resource.data.branchId)
          )
        );
    }

    function pl_canCreateRepairBranchScoped() {
      return pl_sameTenantOrLegacyWrite()
        && (
          pl_isRepairBranchAdmin()
          || (
            'branchId' in request.resource.data
            && pl_canAccessRepairBranch(request.resource.data.branchId)
          )
        );
    }

    function pl_canUpdateRepairBranchScoped() {
      return pl_sameTenantOrLegacyUpdate()
        && (
          pl_isRepairBranchAdmin()
          || (
            'branchId' in resource.data
            && 'branchId' in request.resource.data
            && pl_canAccessRepairBranch(resource.data.branchId)
            && pl_canAccessRepairBranch(request.resource.data.branchId)
          )
        );
    }

    function pl_canCreateRepairTreasuryEntryForOpenSession() {
      return (
        'sessionId' in request.resource.data
        && exists(
          /databases/$(database)/documents/repair_treasury_sessions/$(request.resource.data.sessionId)
        )
        && get(
          /databases/$(database)/documents/repair_treasury_sessions/$(request.resource.data.sessionId)
        ).data.branchId == request.resource.data.branchId
        && get(
          /databases/$(database)/documents/repair_treasury_sessions/$(request.resource.data.sessionId)
        ).data.status == 'open'
        && (
          !('needsManualClose' in get(
            /databases/$(database)/documents/repair_treasury_sessions/$(request.resource.data.sessionId)
          ).data)
          || get(
            /databases/$(database)/documents/repair_treasury_sessions/$(request.resource.data.sessionId)
          ).data.needsManualClose != true
        )
      );
    }

    /**
     * Gradual hardening (after backfillTenantId / data audit):
     * 1. Ensure all business docs in production have tenantId set.
     * 2. Replace pl_sameTenantOrLegacyRead with sameTenant on read for pl_isErpBusinessCollection.
     * 3. Replace pl_sameTenantOrLegacyUpdate with pl_sameTenantUpdate where legacy reads are no longer needed.
     * 4. Keep payroll_* on legacy helpers until those collections are fully migrated.
     */

    function pl_isErpBusinessCollection(coll) {
      return coll in [
        'products', 'production_lines', 'productionLines', 'employees', 'production_reports',
        'production_approval_requests',
        'line_status', 'line_product_config', 'production_plans', 'production_plan_followups',
        'supervisors', 'supervisor_line_assignments', 'supervisorAssignmentLog',
        'production_workers', 'production_line_worker_assignments', 'production_worker_targets',
        'worker_performance_summaries', 'worker_daily_performance_logs', 'production_attendance_records',
        'work_orders', 'notifications', 'scan_events', 'product_materials',
        'materials', 'boms', 'bom_items', 'material_requirement_runs',
        'production_plan_material_requirements', 'purchase_orders',
        'cost_deviation_analysis',
        'line_worker_assignments', 'warehouses', 'raw_materials', 'stock_items', 'stock_transactions',
        'stock_counts', 'inventory_transfer_requests', 'cost_centers', 'cost_center_values',
        'cost_allocations', 'labor_settings', 'assets', 'asset_depreciations',
        'activity_logs', 'departments', 'job_positions', 'shifts', 'hr_settings',
        'penalty_rules', 'late_rules', 'allowance_types', 'attendance_raw_logs', 'attendance_logs',
        'attendance_records', 'attendance_monthly_summaries', 'attendance_import_history',
        'employee_allowances',
        'vehicles', 'approval_settings',
        'employee_performance', 'employee_bonuses',
        'quality_settings', 'quality_reason_catalog', 'quality_workers_assignments',
        'quality_inspections', 'quality_defects', 'quality_rework_orders', 'quality_capa', 'quality_print_logs',
        'production_report_uniques', 'product_categories', 'material_categories', 'automation_runs', 'backups',
        'production_routing_plans', 'production_routing_steps',
        'supply_cycles', 'supply_cycle_waste_lines',
        'entity_code_counters', 'inventory_counters'
      ];
    }

    /**
     * Super admins may work inside another company via /t/{slug}/… while their users/{uid}.tenantId
     * stays on a home tenant. Generic business rules must still allow tenant-scoped docs.
     */
    function pl_superAdminTenantScopedCreateOk() {
      return pl_isSuperAdmin()
        && request.resource.data.keys().hasAll(['tenantId'])
        && request.resource.data.tenantId is string
        && request.resource.data.tenantId != '';
    }

    function pl_superAdminTenantScopedUpdateOk() {
      return pl_isSuperAdmin()
        && (
          !('tenantId' in resource.data)
          || !('tenantId' in request.resource.data)
          || request.resource.data.tenantId == resource.data.tenantId
        );
    }

    function pl_canManageHrConfigModule(moduleId) {
      return pl_isSuperAdmin()
        || pl_hasErpPermission('hrSettings.edit')
        || pl_hasErpPermission('settings.edit')
        || (moduleId == 'leave' && pl_hasErpPermission('leave.manage'));
    }

    function pl_canCreateHrConfigAuditLog() {
      return pl_isSuperAdmin()
        || pl_hasErpPermission('hrSettings.edit')
        || pl_hasErpPermission('settings.edit')
        || (
          'module' in request.resource.data
          && request.resource.data.module is string
          && request.resource.data.module == 'leave'
          && pl_hasErpPermission('leave.manage')
        );
    }

    function pl_hasSupervisorRequestPermission() {
      return pl_hasErpPermission('employeeDashboard.view')
        || pl_hasErpPermission('quickAction.view')
        || pl_hasErpPermission('production.workerReports.view')
        || pl_hasErpPermission('reports.create')
        || pl_hasErpPermission('leave.manage')
        || pl_hasErpPermission('approval.view')
        || pl_hasErpPermission('approval.manage');
    }

    function pl_hasApprovalReadPermission() {
      return pl_hasErpPermission('approval.view')
        || pl_hasErpPermission('approval.manage')
        || pl_hasErpPermission('approval.override')
        || pl_hasErpPermission('approval.escalate');
    }

    function pl_hasApprovalWritePermission() {
      return pl_hasErpPermission('approval.view')
        || pl_hasErpPermission('approval.manage')
        || pl_hasErpPermission('approval.override');
    }

    function pl_hasProductionApprovalReadAllPermission() {
      return pl_hasErpPermission('production.workers.manage')
        || pl_hasErpPermission('production.workerReports.view')
        || pl_hasErpPermission('leave.manage')
        || pl_hasErpPermission('approval.view')
        || pl_hasErpPermission('approval.manage');
    }

    function pl_isApprovalParticipantDoc() {
      return pl_authSignedIn()
        && 'participantUserIds' in resource.data
        && resource.data.participantUserIds is list
        && resource.data.participantUserIds.hasAny([request.auth.uid]);
    }

    function pl_isCurrentApprovalActorDoc() {
      return pl_authSignedIn()
        && 'currentApproverUserIds' in resource.data
        && resource.data.currentApproverUserIds is list
        && resource.data.currentApproverUserIds.hasAny([request.auth.uid]);
    }

    function pl_isCurrentApprovalActionUpdate() {
      return pl_isCurrentApprovalActorDoc()
        && resource.data.status in ['pending', 'in_progress', 'escalated']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'approvalChain', 'currentStep', 'status', 'updatedAt', 'history',
          'currentApproverEmployeeIds', 'currentApproverUserIds',
          'participantEmployeeIds', 'participantUserIds'
        ])
        && request.resource.data.history is list
        && resource.data.history is list
        && request.resource.data.history.size() == resource.data.history.size() + 1;
    }

    function pl_isConfiguredProductionRequestObserverDoc() {
      return pl_authSignedIn()
        && 'tenantId' in resource.data
        && exists(/databases/$(database)/documents/system_settings/$(resource.data.tenantId))
        && 'planSettings' in get(/databases/$(database)/documents/system_settings/$(resource.data.tenantId)).data
        && 'productionRequestObserverUserIds' in get(/databases/$(database)/documents/system_settings/$(resource.data.tenantId)).data.planSettings
        && get(/databases/$(database)/documents/system_settings/$(resource.data.tenantId)).data.planSettings.productionRequestObserverUserIds is list
        && get(/databases/$(database)/documents/system_settings/$(resource.data.tenantId)).data.planSettings.productionRequestObserverUserIds.hasAny([request.auth.uid]);
    }

    function pl_isOwnCreatedDoc() {
      return pl_authSignedIn()
        && 'createdBy' in resource.data
        && resource.data.createdBy == request.auth.uid;
    }

    function pl_isOwnCreatedWrite() {
      return pl_authSignedIn()
        && 'createdBy' in request.resource.data
        && request.resource.data.createdBy == request.auth.uid;
    }

    function pl_isOwnApprovalCreatorCancellationUpdate() {
      return pl_isOwnCreatedDoc()
        && resource.data.status == 'pending'
        && resource.data.currentStep == 0
        && request.resource.data.status == 'cancelled'
        && request.resource.data.currentStep == resource.data.currentStep
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'history'])
        && request.resource.data.history is list
        && resource.data.history is list
        && request.resource.data.history.size() == resource.data.history.size() + 1
        && (
          !('approvalChain' in resource.data)
          || resource.data.approvalChain.size() == 0
          || resource.data.approvalChain[0].status == 'pending'
        );
    }

    function pl_isOwnProductionApprovalCreatorCancellationUpdate() {
      return pl_isOwnCreatedDoc()
        && resource.data.status == 'pending'
        && resource.data.currentStep == 0
        && request.resource.data.status == 'cancelled'
        && request.resource.data.currentStep == resource.data.currentStep
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'updatedAt', 'history',
          'currentApproverEmployeeIds', 'currentApproverUserIds',
          'participantEmployeeIds', 'participantUserIds'
        ])
        && request.resource.data.history is list
        && resource.data.history is list
        && request.resource.data.history.size() == resource.data.history.size() + 1
        && (
          !('approvalChain' in resource.data)
          || resource.data.approvalChain.size() == 0
          || resource.data.approvalChain[0].status == 'pending'
        );
    }

    function pl_isOwnPendingSourceCancellationUpdate() {
      return pl_isOwnCreatedDoc()
        && (!('finalStatus' in resource.data) || resource.data.finalStatus == 'pending')
        && request.resource.data.finalStatus == 'rejected'
        && request.resource.data.status in ['pending', 'rejected']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvalChain', 'finalStatus', 'status']);
    }

    function pl_isOwnNotification() {
      return pl_authSignedIn()
        && 'recipientUserId' in resource.data
        && resource.data.recipientUserId == request.auth.uid;
    }

    function pl_isSpecialHrWorkflowCollection(coll) {
      return coll in [
        'leave_requests', 'leave_balances', 'employee_loans', 'employee_deductions',
        'approval_requests', 'production_approval_requests', 'approval_delegations',
        'approval_audit_logs', 'hr_notifications'
      ];
    }

    function pl_isPresenceOwner(userId) {
      return pl_authSignedIn() && request.auth.uid == userId;
    }

    match /tenant_slugs/{slug} {
      allow read: if pl_authSignedIn();
      allow write: if pl_isSuperAdmin();
    }

    match /tenants/{tenantId} {
      allow read: if pl_isActiveUser() && pl_currentUserDoc().data.tenantId == tenantId;
      allow read: if pl_isSuperAdmin();
      allow create, delete: if pl_isSuperAdmin();
      allow update: if pl_isSuperAdmin()
        || (pl_isActiveUser()
          && pl_currentUserDoc().data.tenantId == tenantId
          && pl_hasErpPermission('settings.edit')
          && request.resource.data.slug == resource.data.slug
          && request.resource.data.status == resource.data.status);
    }

    match /pending_tenants/{id} {
      allow create: if pl_authSignedIn();
      allow read, update: if pl_isSuperAdmin();
      allow delete: if pl_isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if pl_authSignedIn() && request.auth.uid == userId;
      allow get: if pl_authSignedIn() && (
        pl_isSuperAdmin()
        || (pl_isActiveUser() && resource.data.tenantId == pl_currentUserDoc().data.tenantId
          && (pl_hasErpPermission('users.manage') || pl_hasErpPermission('roles.manage')))
      );
      allow list: if pl_authSignedIn() && (
        pl_isSuperAdmin()
        || (pl_isActiveUser() && (pl_hasErpPermission('users.manage') || pl_hasErpPermission('roles.manage')))
      );
      allow create: if (pl_authSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'displayName', 'roleId', 'tenantId', 'isActive']))
        || (pl_isSuperAdmin()
        && request.resource.data.keys().hasAll(['email', 'displayName', 'roleId', 'tenantId', 'isActive']));
      allow update: if pl_authSignedIn() && (
        (request.auth.uid == userId && resource.data.tenantId == pl_currentUserDoc().data.tenantId)
        || (pl_isActiveUser() && resource.data.tenantId == pl_currentUserDoc().data.tenantId
          && (pl_hasErpPermission('users.manage') || pl_hasErpPermission('roles.manage')))
        || pl_isSuperAdmin()
      );
      allow delete: if pl_isSuperAdmin()
        || (pl_isActiveUser() && resource.data.tenantId == pl_currentUserDoc().data.tenantId
          && pl_hasErpPermission('users.manage'));
    }

    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if pl_authSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/preferences/{prefId} {
      allow read, write: if pl_authSignedIn() && request.auth.uid == userId;
    }

    match /roles/{roleId} {
      allow read: if pl_authSignedIn() && (
        pl_isSuperAdmin()
        || (exists(pl_currentUserPath()) && resource.data.tenantId == pl_currentUserDoc().data.tenantId)
      );
      /* Super-admin approves pending companies: seedIfEmpty() creates roles for the NEW tenantId â€” tenant admins use roles.manage on their own tenant. */
      allow create: if pl_isSuperAdmin()
        || (pl_isActiveUser() && pl_hasErpPermission('roles.manage') && pl_sameTenantWrite());
      /* Updates must keep tenantId stable. Deletes have no request.resource â€” pl_sameTenantUpdate() always fails for delete. */
      allow update: if pl_isSuperAdmin()
        || (pl_isActiveUser() && pl_hasErpPermission('roles.manage') && pl_sameTenantUpdate());
      allow delete: if pl_isSuperAdmin()
        || (pl_isActiveUser() && pl_hasErpPermission('roles.manage')
          && resource.data.tenantId == pl_currentUserDoc().data.tenantId);
    }

    match /dashboardStats/{tenantId}/daily/{dayId} {
      allow read: if pl_isActiveUser() && pl_currentUserDoc().data.tenantId == tenantId;
      allow write: if false;
    }

    match /dashboardStats/{tenantId}/monthly/{monthId} {
      allow read: if pl_isActiveUser() && pl_currentUserDoc().data.tenantId == tenantId;
      allow write: if false;
    }

    // Alias hardening for snake_case naming in old docs/references.
    match /dashboard_stats/{tenantId}/{docId} {
      allow read: if pl_isActiveUser() && pl_currentUserDoc().data.tenantId == tenantId;
      allow write: if false;
    }

    match /audit_logs/{docId} {
      allow read: if pl_isActiveUser() && pl_sameTenantOrLegacyRead();
      // auditQueue.service + audit.service create tenant-scoped logs from the client.
      allow create: if pl_isActiveUser()
        && request.resource.data.tenantId == pl_currentUserDoc().data.tenantId;
      allow update, delete: if false;
    }

    match /audit_logs/{docId}/{subPath=**} {
      allow read: if pl_isActiveUser();
      allow write: if false;
    }

    // Same tenant isolation as pl_isErpBusinessCollection writes, but NOT listed there so
    // generic delete (open on many collections) does not apply to financial snapshots.
    match /monthly_production_costs/{docId} {
      allow read: if pl_isActiveUser() && pl_sameTenantOrLegacyRead();
      allow create: if pl_isActiveUser() && pl_sameTenantOrLegacyWrite();
      allow update: if pl_isActiveUser() && pl_sameTenantOrLegacyUpdate();
      allow delete: if false;
    }

    // Alias for requested monthly_costs naming.
    match /monthly_costs/{docId} {
      allow read: if pl_isActiveUser() && pl_sameTenantOrLegacyRead();
      allow create: if pl_isActiveUser() && pl_sameTenantOrLegacyWrite();
      allow update: if pl_isActiveUser() && pl_sameTenantOrLegacyUpdate();
      allow delete: if false;
    }

    match /user_presence/{userId} {
      allow read: if pl_hasErpPermission('activityLog.view') || pl_hasErpPermission('roles.manage');
      allow create, update, delete: if pl_isPresenceOwner(userId);
    }

    match /user_devices/{tokenId} {
      allow read: if pl_authSignedIn()
        && (resource.data.userId == request.auth.uid || pl_hasErpPermission('roles.manage'));
      allow create: if pl_authSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if pl_authSignedIn()
        && (resource.data.userId == request.auth.uid || pl_hasErpPermission('roles.manage'));
    }

    match /payroll_months/{monthId} {
      allow read: if pl_isActiveUser() && pl_sameTenantOrLegacyRead();
      allow create: if pl_hasErpPermission('payroll.generate') && pl_sameTenantOrLegacyWrite();
      allow delete: if pl_hasErpPermission('payroll.generate') && pl_sameTenantOrLegacyRead();
      allow update: if (pl_hasErpPermission('payroll.generate')
        || pl_hasErpPermission('payroll.finalize')
        || pl_hasErpPermission('payroll.lock'))
        && pl_sameTenantOrLegacyUpdate();
    }

    match /payroll_records/{recordId} {
      allow read: if (pl_hasErpPermission('payroll.view')
        || pl_hasErpPermission('payroll.generate')
        || pl_hasErpPermission('payroll.finalize')
        || pl_hasErpPermission('payroll.lock')
        || pl_hasErpPermission('payroll.accounts.view')
        || pl_hasErpPermission('payroll.accounts.disburse'))
        && pl_sameTenantOrLegacyRead();
      allow create: if pl_hasErpPermission('payroll.generate') && pl_sameTenantOrLegacyWrite();
      allow delete: if pl_hasErpPermission('payroll.generate') && pl_sameTenantOrLegacyRead();
      allow update: if (
          pl_hasErpPermission('payroll.generate')
          || pl_hasErpPermission('payroll.finalize')
          || pl_hasErpPermission('payroll.lock')
          || pl_hasErpPermission('payroll.accounts.disburse')
        )
        && pl_sameTenantOrLegacyUpdate();
    }

    match /payroll_audit_logs/{logId} {
      allow read: if pl_isActiveUser() && pl_sameTenantOrLegacyRead();
      allow create: if (pl_hasErpPermission('payroll.generate')
        || pl_hasErpPermission('payroll.finalize')
        || pl_hasErpPermission('payroll.lock'))
        && pl_sameTenantOrLegacyWrite();
    }

    match /payroll_cost_summary/{summaryId} {
      allow read: if pl_isActiveUser() && pl_sameTenantOrLegacyRead();
      allow create, update: if (pl_hasErpPermission('payroll.finalize')
        || pl_hasErpPermission('payroll.lock'))
        && pl_sameTenantOrLegacyWrite();
      allow delete: if (pl_hasErpPermission('payroll.finalize')
        || pl_hasErpPermission('payroll.lock'))
        && pl_sameTenantOrLegacyRead();
    }

    match /payroll_distributions/{distributionId} {
      allow read: if (pl_hasErpPermission('payroll.view') || pl_hasErpPermission('payroll.accounts.view')) && pl_sameTenantOrLegacyRead();
      allow create, update: if pl_hasErpPermission('payroll.accounts.disburse') && pl_sameTenantOrLegacyWrite();
      allow delete: if pl_hasErpPermission('payroll.accounts.disburse') && pl_sameTenantOrLegacyRead();
    }

    match /repair_branches/{id} {
      allow read: if pl_sameTenantOrLegacyRead() && (
        pl_isRepairBranchAdmin()
        || pl_hasErpPermission('repair.view')
        || pl_hasErpPermission('repair.dashboard.view')
        || pl_hasErpPermission('repair.parts.view')
        || pl_hasErpPermission('repair.parts.manage')
        || pl_hasErpPermission('repair.treasury.view')
        || pl_hasErpPermission('repair.treasury.manage')
        || pl_hasErpPermission('repair.salesInvoice.create')
        || pl_hasErpPermission('repair.salesInvoice.view')
      );
      allow create, update: if pl_isRepairBranchAdmin() && pl_sameTenantOrLegacyWrite();
      allow delete: if pl_isRepairBranchAdmin() && pl_sameTenantOrLegacyRead();
    }

    match /repair_jobs/{id} {
      allow read: if pl_hasErpPermission('repair.view') && pl_canReadRepairBranchScoped();
      allow create: if pl_hasErpPermission('repair.jobs.create') && pl_canCreateRepairBranchScoped();
      allow update: if pl_hasErpPermission('repair.jobs.edit') && pl_canUpdateRepairBranchScoped();
      allow delete: if pl_hasErpPermission('repair.jobs.delete') && pl_canReadRepairBranchScoped();
    }

    match /repair_jobs/{jobId}/service_events/{eventId} {
      allow read: if pl_hasErpPermission('repair.view') && pl_canReadRepairBranchScoped();
      allow create: if pl_hasErpPermission('repair.jobs.create') && pl_canCreateRepairBranchScoped();
      allow update: if pl_hasErpPermission('repair.jobs.edit') && pl_canUpdateRepairBranchScoped();
      allow delete: if pl_hasErpPermission('repair.jobs.delete') && pl_canReadRepairBranchScoped();
    }

    match /repair_part_reservations/{id} {
      allow read: if pl_hasErpPermission('repair.parts.view') && pl_canReadRepairBranchScoped();
      allow create, update: if pl_hasErpPermission('repair.parts.manage') && pl_canCreateRepairBranchScoped();
      allow delete: if pl_hasErpPermission('repair.parts.manage') && pl_canReadRepairBranchScoped();
    }

    match /repair_spare_parts/{id} {
      allow read: if pl_hasErpPermission('repair.parts.view') && pl_canReadRepairBranchScoped();
      allow create, update: if pl_hasErpPermission('repair.parts.manage') && pl_canCreateRepairBranchScoped();
      allow delete: if pl_hasErpPermission('repair.parts.manage') && pl_canReadRepairBranchScoped();
    }

    match /repair_spare_parts_stock/{id} {
      allow read: if pl_hasErpPermission('repair.parts.view') && pl_canReadRepairBranchScoped();
      allow create, update: if pl_hasErpPermission('repair.parts.manage') && pl_canCreateRepairBranchScoped();
      allow delete: if pl_hasErpPermission('repair.parts.manage') && pl_canReadRepairBranchScoped();
    }

    match /repair_parts_transactions/{id} {
      allow read: if pl_hasErpPermission('repair.parts.view') && pl_canReadRepairBranchScoped();
      allow create: if pl_hasErpPermission('repair.parts.manage') && pl_canCreateRepairBranchScoped();
      allow update, delete: if false;
    }

    match /repair_treasury_sessions/{id} {
      allow read: if (
          pl_hasErpPermission('repair.treasury.view')
          || pl_hasErpPermission('repair.treasury.manage')
        ) && pl_canReadRepairBranchScoped();
      allow create: if pl_hasErpPermission('repair.treasury.manage') && pl_canCreateRepairBranchScoped();
      allow update: if pl_hasErpPermission('repair.treasury.manage') && pl_canUpdateRepairBranchScoped();
      allow delete: if false;
    }

    match /repair_treasury_entries/{id} {
      allow read: if (
          pl_hasErpPermission('repair.treasury.view')
          || pl_hasErpPermission('repair.treasury.manage')
        ) && pl_canReadRepairBranchScoped();
      allow create: if pl_hasErpPermission('repair.treasury.manage')
        && pl_canCreateRepairBranchScoped()
        && pl_canCreateRepairTreasuryEntryForOpenSession();
      allow update, delete: if false;
    }

    match /repair_sales_invoices/{id} {
      allow read: if (
          pl_hasErpPermission('repair.salesInvoice.view')
          || pl_hasErpPermission('repair.salesInvoice.create')
        ) && pl_canReadRepairBranchScoped();
      allow create: if pl_hasErpPermission('repair.salesInvoice.create') && pl_canCreateRepairBranchScoped();
      allow update: if (
          pl_hasErpPermission('repair.salesInvoice.edit')
          || pl_hasErpPermission('repair.salesInvoice.cancel')
        ) && pl_canUpdateRepairBranchScoped();
      allow delete: if false;
    }

    match /_counters/{id} {
      allow read: if pl_isActiveUser()
        && resource.data.tenantId == pl_currentUserDoc().data.tenantId
        && pl_hasErpPermission('repair.jobs.create');
      allow create: if pl_isActiveUser()
        && request.resource.data.tenantId == pl_currentUserDoc().data.tenantId
        && pl_hasErpPermission('repair.jobs.create');
      allow update: if pl_isActiveUser()
        && resource.data.tenantId == pl_currentUserDoc().data.tenantId
        && request.resource.data.tenantId == pl_currentUserDoc().data.tenantId
        && pl_hasErpPermission('repair.jobs.create');
      allow delete: if false;
    }


    match /production_routing_executions/{docId} {
      allow read: if pl_isActiveUser() && pl_sameTenantOrLegacyRead();
      allow create: if pl_isActiveUser() && pl_sameTenantOrLegacyWrite();
      allow update: if pl_isActiveUser() && pl_sameTenantOrLegacyUpdate()
        && resource.data.status != 'completed';
      allow delete: if pl_isActiveUser() && pl_sameTenantOrLegacyRead() && pl_hasErpPermission('routing.manage');
    }

    match /production_routing_execution_steps/{docId} {
      allow read: if pl_isActiveUser() && pl_sameTenantOrLegacyRead();
      allow create: if pl_isActiveUser() && pl_sameTenantOrLegacyWrite()
        && get(/databases/$(database)/documents/production_routing_executions/$(request.resource.data.executionId)).data.status != 'completed';
      allow update: if pl_isActiveUser() && pl_sameTenantOrLegacyUpdate()
        && get(/databases/$(database)/documents/production_routing_executions/$(resource.data.executionId)).data.status != 'completed';
      allow delete: if pl_isActiveUser() && pl_sameTenantOrLegacyRead()
        && (
          get(/databases/$(database)/documents/production_routing_executions/$(resource.data.executionId)).data.status != 'completed'
          || pl_hasErpPermission('routing.manage')
        );
    }

    match /production_report_uniques/{docId} {
      allow read: if pl_isActiveUser()
        && (
          !exists(/databases/$(database)/documents/production_report_uniques/$(docId))
          || !('tenantId' in resource.data)
          || resource.data.tenantId == pl_currentUserDoc().data.tenantId
          || pl_isSuperAdmin()
        );
      allow create: if pl_isActiveUser()
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if pl_isActiveUser()
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if pl_isActiveUser()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
    }

    match /hr_config_modules/{moduleId} {
      allow read: if pl_isActiveUser()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if pl_canManageHrConfigModule(moduleId)
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if pl_canManageHrConfigModule(moduleId)
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if false;
    }

    match /hr_config_audit_logs/{logId} {
      allow read: if pl_isActiveUser()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if pl_canCreateHrConfigAuditLog()
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update, delete: if false;
    }

    match /leave_balances/{docId} {
      allow read: if pl_isActiveUser()
        && pl_hasSupervisorRequestPermission()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if pl_hasSupervisorRequestPermission()
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if (pl_hasErpPermission('leave.manage') || pl_hasErpPermission('approval.manage'))
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if false;
    }

    match /leave_requests/{docId} {
      allow read: if pl_isActiveUser()
        && (pl_hasSupervisorRequestPermission() || pl_isOwnCreatedDoc())
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if pl_hasSupervisorRequestPermission()
        && pl_isOwnCreatedWrite()
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if (pl_hasApprovalWritePermission() || pl_hasErpPermission('leave.manage') || pl_isOwnPendingSourceCancellationUpdate())
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if pl_isOwnCreatedDoc()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin())
        && (!('finalStatus' in resource.data) || resource.data.finalStatus == 'pending');
    }

    match /employee_loans/{docId} {
      allow read: if pl_isActiveUser()
        && (pl_hasSupervisorRequestPermission() || pl_isOwnCreatedDoc())
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if pl_hasSupervisorRequestPermission()
        && pl_isOwnCreatedWrite()
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if (pl_hasApprovalWritePermission() || pl_hasErpPermission('loan.manage') || pl_hasErpPermission('loan.disburse') || pl_isOwnPendingSourceCancellationUpdate())
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if pl_isOwnCreatedDoc()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin())
        && (!('finalStatus' in resource.data) || resource.data.finalStatus == 'pending');
    }

    match /employee_deductions/{docId} {
      allow read: if pl_isActiveUser()
        && (pl_hasSupervisorRequestPermission() || pl_hasErpPermission('payroll.view'))
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if (pl_hasApprovalWritePermission() || pl_hasErpPermission('payroll.generate') || pl_hasErpPermission('hrSettings.edit'))
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if (pl_hasErpPermission('payroll.generate') || pl_hasErpPermission('hrSettings.edit'))
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if (pl_hasErpPermission('payroll.generate') || pl_hasErpPermission('hrSettings.edit'))
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
    }

    match /approval_requests/{docId} {
      allow read: if pl_isActiveUser()
        && (pl_hasApprovalReadPermission() || pl_isOwnCreatedDoc() || pl_isApprovalParticipantDoc() || pl_isCurrentApprovalActorDoc())
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if pl_hasSupervisorRequestPermission()
        && pl_isOwnCreatedWrite()
        && request.resource.data.keys().hasAll([
          'tenantId', 'requestType', 'employeeId', 'requestData', 'approvalChain',
          'currentStep', 'status', 'history', 'createdBy'
        ])
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if (pl_hasApprovalWritePermission() || pl_isCurrentApprovalActionUpdate() || pl_isOwnApprovalCreatorCancellationUpdate())
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if false;
    }

    match /approval_delegations/{docId} {
      allow read: if pl_isActiveUser()
        && (pl_hasSupervisorRequestPermission() || pl_hasApprovalReadPermission())
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if pl_hasErpPermission('approval.delegate')
        && pl_isOwnCreatedWrite()
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if pl_hasErpPermission('approval.delegate')
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if false;
    }

    match /approval_audit_logs/{docId} {
      allow read: if pl_hasApprovalReadPermission()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if (pl_hasSupervisorRequestPermission() || pl_hasApprovalWritePermission())
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update, delete: if false;
    }

    match /hr_notifications/{docId} {
      allow read: if pl_isOwnNotification()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if (pl_hasSupervisorRequestPermission() || pl_hasApprovalWritePermission())
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if pl_isOwnNotification()
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk())
        && request.resource.data.recipientUserId == resource.data.recipientUserId;
      allow delete: if false;
    }

    match /production_approval_requests/{docId} {
      allow read: if pl_isActiveUser()
        && (
          pl_hasProductionApprovalReadAllPermission()
          || pl_isOwnCreatedDoc()
          || pl_isApprovalParticipantDoc()
          || pl_isCurrentApprovalActorDoc()
          || pl_isConfiguredProductionRequestObserverDoc()
        )
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if pl_hasSupervisorRequestPermission()
        && pl_isOwnCreatedWrite()
        && request.resource.data.keys().hasAll([
          'tenantId', 'requestType', 'employeeId', 'requestData', 'approvalChain',
          'currentStep', 'status', 'history', 'createdBy'
        ])
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if (pl_hasApprovalWritePermission() || pl_isCurrentApprovalActionUpdate() || pl_isOwnProductionApprovalCreatorCancellationUpdate())
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if false;
    }

    match /system_settings/{docId} {
      allow read: if pl_isActiveUser()
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if (
          pl_isSuperAdmin()
          || (pl_isActiveUser()
            && (pl_hasErpPermission('settings.edit') || pl_hasErpPermission('roles.manage'))
            && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk()))
        );
      allow update: if (
          pl_isSuperAdmin()
          || (pl_isActiveUser()
            && (pl_hasErpPermission('settings.edit') || pl_hasErpPermission('roles.manage'))
            && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk()))
        );
      allow delete: if false;
    }

    match /{coll}/{docId} {
      allow read: if !pl_isSpecialHrWorkflowCollection(coll) && pl_isErpBusinessCollection(coll)
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
      allow create: if !pl_isSpecialHrWorkflowCollection(coll) && pl_isErpBusinessCollection(coll)
        && (pl_sameTenantOrLegacyWrite() || pl_superAdminTenantScopedCreateOk());
      allow update: if !pl_isSpecialHrWorkflowCollection(coll) && pl_isErpBusinessCollection(coll)
        && (pl_sameTenantOrLegacyUpdate() || pl_superAdminTenantScopedUpdateOk());
      allow delete: if !pl_isSpecialHrWorkflowCollection(coll) && pl_isErpBusinessCollection(coll)
        && (pl_sameTenantOrLegacyRead() || pl_isSuperAdmin());
    }

  }
}

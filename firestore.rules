rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentRolePath() {
      return /databases/$(database)/documents/roles/$(currentUserDoc().data.roleId);
    }

    function currentRoleDoc() {
      return get(currentRolePath());
    }

    function hasPermission(permissionKey) {
      return isAuthenticated()
        && exists(currentUserPath())
        && exists(currentRolePath())
        && currentRoleDoc().data.permissions[permissionKey] == true;
    }

    function isActiveUser() {
      return isAuthenticated()
        && exists(currentUserPath())
        && currentUserDoc().data.isActive == true;
    }

    function isBootstrap() {
      return isAuthenticated() && !exists(currentUserPath());
    }

    function isPresenceOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /user_presence/{userId} {
      allow read: if hasPermission('activityLog.view') || hasPermission('roles.manage');
      allow create, update, delete: if isPresenceOwner(userId);
    }

    match /user_devices/{tokenId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || hasPermission('roles.manage'));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || hasPermission('roles.manage'));
    }

    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Payroll hardening (Phase 1): explicit least-privilege rules for sensitive writes.
    match /payroll_months/{monthId} {
      allow read: if isActiveUser();
      allow create, delete: if hasPermission('payroll.generate');
      allow update: if hasPermission('payroll.generate')
        || hasPermission('payroll.finalize')
        || hasPermission('payroll.lock');
    }

    match /payroll_records/{recordId} {
      allow read: if isActiveUser();
      allow create, delete: if hasPermission('payroll.generate');
      allow update: if hasPermission('payroll.generate')
        || hasPermission('payroll.finalize')
        || hasPermission('payroll.lock')
        || hasPermission('payroll.accounts.disburse');
    }

    match /payroll_audit_logs/{logId} {
      allow read: if isActiveUser();
      allow create: if hasPermission('payroll.generate')
        || hasPermission('payroll.finalize')
        || hasPermission('payroll.lock');
    }

    match /payroll_cost_summary/{summaryId} {
      allow read: if isActiveUser();
      allow create, update, delete: if hasPermission('payroll.finalize')
        || hasPermission('payroll.lock');
    }

    match /payroll_distributions/{distributionId} {
      allow read: if hasPermission('payroll.view') || hasPermission('payroll.accounts.view');
      allow create, update, delete: if hasPermission('payroll.accounts.disburse');
    }

    match /{document=**} {
      // Temporary baseline hardening:
      // - Active users can continue working.
      // - Bootstrap users (before user doc creation) can complete setup.
      allow read, write: if (isActiveUser() || isBootstrap())
        && !document.matches('payroll_months/.*')
        && !document.matches('payroll_records/.*')
        && !document.matches('payroll_audit_logs/.*')
        && !document.matches('payroll_cost_summary/.*')
        && !document.matches('payroll_distributions/.*');
    }

    // ─── Repair Management Module ───────────────────────────────────────────

    match /repair_branches/{branchId} {
      allow read: if isActiveUser();
      allow create: if hasPermission('repair.branches.manage');
      allow update, delete: if hasPermission('repair.branches.manage');
    }

    match /repair_jobs/{jobId} {
      // Public read: allowed only for tracker (client enforces receiptNo+phone match)
      allow read: if true;
      allow create: if hasPermission('repair.jobs.create');
      allow update: if hasPermission('repair.jobs.edit') || hasPermission('repair.view');
      allow delete: if hasPermission('repair.jobs.delete');
    }

    match /repair_spare_parts/{partId} {
      allow read: if isActiveUser();
      allow create, update: if hasPermission('repair.parts.manage');
      allow delete: if hasPermission('repair.parts.manage');
    }

    match /repair_spare_parts_stock/{stockId} {
      allow read: if isActiveUser();
      allow create, update: if isActiveUser();
    }

    match /repair_parts_transactions/{txId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();
    }

    match /repair_cash_transactions/{txId} {
      allow read: if isActiveUser();
      allow create: if hasPermission('repair.cashier.manage') || hasPermission('repair.cashier.view');
    }

    match /repair_cash_sessions/{sessionId} {
      allow read: if isActiveUser();
      allow create: if hasPermission('repair.cashier.manage');
      allow update: if hasPermission('repair.cashier.close');
    }

    match /repair_sale_invoices/{invoiceId} {
      allow read: if isActiveUser();
      allow create: if hasPermission('repair.sales.create');
    }

    match /repair_technician_branches/{techId} {
      allow read: if isActiveUser();
      allow write: if hasPermission('repair.branches.manage');
    }

    match /_repair_counters/{counterId} {
      allow read, write: if isActiveUser();
    }
  }
}

{
  "name": "pro-tech-erp-functions",
  "private": true,
  "main": "lib/index.js",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "lint": "echo \"No function lint configured\"",
    "backfill:dashboardStats:dry": "npm run build && node lib/scripts/backfillDashboardStats.js --dry-run",
    "backfill:dashboardStats:apply": "npm run build && node lib/scripts/backfillDashboardStats.js --apply"
  },
  "dependencies": {
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.5.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
